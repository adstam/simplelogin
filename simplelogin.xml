<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>Simplelogin</name>
    <author>Ad Stam</author>
    <version>0.8.8</version>
    <creationDate>2026-04-23</creationDate>
    <copyright>Copyright (C) 2026 Ad Stam. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <description><![CDATA[<p>This extension was designed by Ad Stam. The coding was largely done using AI</p><p>Simple Login enables passwordless login via an email link.</p><p><a href=\"https://demo.adstam.nl\" target=\"_blank\">demo.adstam.nl</a>]]></description>

    <namespace path="src" allowoverride="true">Adstam\Plugin\System\Simplelogin</namespace>
    <scriptfile>script.php</scriptfile>

    <files>
        <folder>language</folder>
        <folder>services</folder>
        <folder plugin="simplelogin">src</folder>
        <filename>script.php</filename>
        <folder>layouts</folder>
        <folder>sql</folder>
    </files>

    <media destination="plg_system_simplelogin" folder="media">
        <folder>js</folder>
    </media>

    <services>
        <provider>services/provider.php</provider>
    </services>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <config>
        <fields name="params" addfieldprefix="Adstam\Plugin\System\Simplelogin\Field">

            <fieldset name="general" label="PLG_SYSTEM_SIMPLELOGIN_FIELDSET_GENERAL">

                <field name="landing_page_option"
                       type="radio"
                       label="PLG_SYSTEM_SIMPLELOGIN_LANDING_PAGE_OPTION_LABEL"
                       default="homepage">

                    <option value="homepage">PLG_SYSTEM_SIMPLELOGIN_OPTION_HOMEPAGE</option>
                    <option value="custom">PLG_SYSTEM_SIMPLELOGIN_OPTION_CUSTOM</option>
                </field>

                <field name="landing_itemid"
                       type="menuitem"
                       label="PLG_SYSTEM_SIMPLELOGIN_LANDING_ITEMID_LABEL"
                       showon="landing_page_option:custom" />

                <field name="allow_password_login"
                       type="radio"
                       label="PLG_SYSTEM_SIMPLELOGIN_ALLOW_PASSWORD_LOGIN_LABEL"
                       default="0">

                    <option value="0">PLG_SYSTEM_SIMPLELOGIN_OPTION_NO</option>
                    <option value="1">PLG_SYSTEM_SIMPLELOGIN_OPTION_YES</option>
                </field>

                <field name="bulk_hash_passwords"
                       type="hashpasswords"
                       label="PLG_SYSTEM_SIMPLELOGIN_BULK_HASH_PASSWORDS_LABEL"
                       description="PLG_SYSTEM_SIMPLELOGIN_BULK_HASH_PASSWORDS_DESC"
                       showon="allow_password_login:0"/>
            </fieldset>

            <fieldset name="loginmail" label="PLG_SYSTEM_SIMPLELOGIN_FIELDSET_LOGINMAIL">

                <field name="mail_login_subject"
                       type="text"
                       label="PLG_SYSTEM_SIMPLELOGIN_FIELD LOGINMAIL_SUBJECT_LABEL"
                       default="Here's your login link" />

                <field name="mail_login_body"
                       type="textarea"
                       label="PLG_SYSTEM_SIMPLELOGIN_FIELD_LOGINMAIL_BODY_LABEL"
                       description="PLG_SYSTEM_SIMPLELOGIN_FIELD_LOGINMAIL_BODY_DESC"
											 default="#name, &#13;&#10;&#13;&#10;Here's your link to login: &#13;&#10;#link &#13;&#10;&#13;&#10;Please note that the link is valid for #expiry minutes."
                       filter="raw"
                       rows="10"
                       cols="60"/>
            </fieldset>

            <fieldset name="invitemail" label="PLG_SYSTEM_SIMPLELOGIN_FIELDSET_INVITEMAIL">

                <field name="mail_invite_subject"
                       type="text"
                       label="PLG_SYSTEM_SIMPLELOGIN_FIELD_INVITEMAIL_SUBJECT_LABEL"
                       default="Your confirmation link" />

                <field name="mail_invite_body"
                       type="textarea"
                       label="PLG_SYSTEM_SIMPLELOGIN_FIELD_INVITEMAIL_BODY_LABEL"
											 default="#name, &#13;&#10;&#13;&#10;Here's your link to confirm you registration: &#13;&#10;#link &#13;&#10;&#13;&#10;Please note that the link is valid for #expiry minutes."
                       description="PLG_SYSTEM_SIMPLELOGIN_FIELD_INVITEMAIL_BODY_DESC"
                       filter="raw"
											 rows="10"
                       cols="60"/>
            </fieldset>

            <fieldset name="security" label="PLG_SYSTEM_SIMPLELOGIN_FIELDSET_SECURITY">

                <field name="kopbasis"
                       type="spacer"
                       label="PLG_SYSTEM_SIMPLELOGIN_SECURITY_BASE_LIMITS" />

                <field name="expiry_minutes"
                       type="number"
                       label="PLG_SYSTEM_SIMPLELOGIN_EXPIRY_MINUTES_LABEL"
                       default="15" />

                <field name="invite_expiry_minutes"
                       type="number"
                       label="PLG_SYSTEM_SIMPLELOGIN_INVITE_EXPIRY_MINUTES_LABEL"
                       default="30" />

                <field name="request_cooldown_seconds"
                       type="number"
                       label="PLG_SYSTEM_SIMPLELOGIN_REQUEST_COOLDOWN_SECONDS_LABEL"
                       default="30" />

                <field name="kopratelimit"
                       type="spacer"
                       label="PLG_SYSTEM_SIMPLELOGIN_SECURITY_RATE_LIMITS" />

                <field name="rate_limit_ip_max"
                       type="number"
                       label="PLG_SYSTEM_SIMPLELOGIN_RATE_LIMIT_IP_MAX_LABEL"
                       default="10" />

                <field name="rate_limit_ip_window"
                       type="number"
                       label="PLG_SYSTEM_SIMPLELOGIN_RATE_LIMIT_IP_WINDOW_LABEL"
                       default="5" />

                <field name="rate_limit_user_max"
                       type="number"
                       label="PLG_SYSTEM_SIMPLELOGIN_RATE_LIMIT_USER_MAX_LABEL"
                       default="5" />

                <field name="rate_limit_user_window"
                       type="number"
                       label="PLG_SYSTEM_SIMPLELOGIN_RATE_LIMIT_USER_WINDOW_LABEL"
                       default="10" />
            </fieldset>

            <fieldset name="throttle_report" label="PLG_SYSTEM_SIMPLELOGIN_FIELDSET_SESSIONS" description="PLG_SYSTEM_SIMPLELOGIN_FIELDSET_SESSIONS_DESCRIPTION">
											 <field name="throttle_cleanup_time"
                       				type="number"
                       				label="PLG_SYSTEM_SIMPLELOGIN_THROTTLE_CLEANUP_TIME_VALUE"
                       				default="60"
															description="PLG_SYSTEM_SIMPLELOGIN_THROTTLE_CLEANUP_TIME_DESCRIPTION" />

                <field name="throttle_report" type="throttlereport" label="" />
            </fieldset>

            <fieldset name="log_report" label="PLG_SYSTEM_SIMPLELOGIN_FIELDSET_LOGGING" description="PLG_SYSTEM_SIMPLELOGIN_FIELDSET_LOGGING_DESCRIPTION">
                <field name="log_export" type="exportlog" label="" />
                <field name="log_retention_days"
                       type="number"
                       label="PLG_SYSTEM_SIMPLELOGIN_LOG_CLEANUP_TIME_VALUE"
                       default="30"
                       description="PLG_SYSTEM_SIMPLELOGIN_LOG_CLEANUP_TIME_DESCRIPTION" />
                <field name="log_report" type="logreport" label="" />
            </fieldset>

        </fields>
    </config>
		<updateservers>
    <server type="extension" priority="1" name="SimpleLogin Updates">
        https://raw.githubusercontent.com/adstam/simplelogin/main/update.xml
    </server>
</updateservers>
</extension>